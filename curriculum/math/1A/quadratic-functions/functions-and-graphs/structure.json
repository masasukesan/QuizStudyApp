    },
    {
      "pattern_id": "standard-to-vertex",
      "description": "y=ax²+bx+c を平方完成して頂点形式に変換",
      "thinking_process": [
        "ax²+bx = a(x+b/2a)² - b²/4a",
        "頂点(-b/2a, c-b²/4a)"
      ],
      "common_mistakes": [
        "a≠1 のとき a で割らずに平方完成",
        "符号ミス"
      ],
      "difficulty": "standard"
    },
    {
