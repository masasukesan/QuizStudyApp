{
  "gqe-001": {
    "lead": "D=16-12=4>0: 2交点。",
    "steps": [
      "D=4>0"
    ],
    "common_mistakes": [
      "1点"
    ]
  },
  "gqe-002": {
    "lead": "D=4-4=0: 1点（重解）。",
    "steps": [
      "D=0"
    ],
    "common_mistakes": [
      "2点"
    ]
  },
  "gqe-003": {
    "lead": "D=1-4=-3<0: 0点。",
    "steps": [
      "D<0"
    ],
    "common_mistakes": [
      "1点"
    ]
  },
  "gqe-004": {
    "lead": "D=36-4k>0: k<9。",
    "steps": [
      "D>0→k<9"
    ],
    "common_mistakes": [
      "k>9"
    ]
  },
  "gqe-005": {
    "lead": "(x+3)(x-1)=0: x=-3,1。",
    "steps": [
      "x=-3,1"
    ],
    "common_mistakes": [
      "符号ミス"
    ]
  },
  "gqe-006": {
    "lead": "(x-2)²=0: x=2。重解点(2,0)。",
    "steps": [
      "x=2"
    ],
    "common_mistakes": [
      "(4,0)"
    ]
  },
  "gqe-007": {
    "lead": "D=p²-16<0: -4<p<4。",
    "steps": [
      "p²<16",
      "-4<p<4"
    ],
    "common_mistakes": [
      "外側"
    ]
  },
  "gqe-008": {
    "lead": "-x²+4=0: x=±2。",
    "steps": [
      "x=±2"
    ],
    "common_mistakes": [
      "(4,0)"
    ]
  },
  "gqe-009": {
    "lead": "(2x+1)(x-2)=0: x=-1/2,2。正はx=2。",
    "steps": [
      "x=2"
    ],
    "common_mistakes": [
      "x=1/2"
    ]
  },
  "gqe-010": {
    "lead": "x=0: y=-3。",
    "steps": [
      "y(0)=-3"
    ],
    "common_mistakes": [
      "3"
    ]
  },
  "gqe-011": {
    "lead": "x²-2x-3=(x-3)(x+1)=0: x=-1,3。",
    "steps": [
      "x=-1,3"
    ],
    "common_mistakes": [
      "符号ミス"
    ]
  },
  "gqe-012": {
    "lead": "x²-4x+3=(x-1)(x-3)=0: x=1,3→2交点。",
    "steps": [
      "2交点"
    ],
    "common_mistakes": [
      "重解と混同"
    ]
  },
  "gqe-013": {
    "lead": "x²-x-k=0。D=1+4k=0: k=-1/4。",
    "steps": [
      "D=1+4k=0→k=-1/4"
    ],
    "common_mistakes": [
      "k=1/4"
    ]
  },
  "gqe-014": {
    "lead": "頂点y=-1。k>-1で2交点。",
    "steps": [
      "k>-1"
    ],
    "common_mistakes": [
      "k>=-1"
    ]
  },
  "gqe-015": {
    "lead": "-(x-3)(x+1)>0: -1<x<3。",
    "steps": [
      "-1<x<3"
    ],
    "common_mistakes": [
      "外側"
    ]
  },
  "gqe-016": {
    "lead": "交点y=1とy=4。積=4。",
    "steps": [
      "(x-1)(x+2)=0",
      "y(1)=1,y(-2)=4",
      "積=4"
    ],
    "common_mistakes": [
      "x座標の積"
    ]
  },
  "gqe-017": {
    "lead": "x²-4x+2=0。解の和=4（解と係数の関係）。",
    "steps": [
      "x²-4x+2=0",
      "和=4"
    ],
    "common_mistakes": [
      "-4: -(b/a)のマイナスを忘れた",
      "3: y=xを引く前の係数を使った",
      "2: 移項ミス"
    ]
  },
  "gqe-018": {
    "lead": "x²-mx+1=0。D=m²-4=0: m=±2。",
    "steps": [
      "D=m²-4=0",
      "m=±2"
    ],
    "common_mistakes": [
      "m=±4"
    ]
  },
  "gqe-019": {
    "lead": "x²-4x+(3-k)=0。D=4+4k≥0: k≥-1。",
    "steps": [
      "D=4+4k≥0",
      "k≥-1"
    ],
    "common_mistakes": [
      "等号なし"
    ]
  },
  "gqe-020": {
    "lead": "y=(x-1)(x-3): b=-4, c=3, b+c=-1。",
    "steps": [
      "b+c=-4+3=-1"
    ],
    "common_mistakes": [
      "1: 根の符号を間違えた",
      "3: |b|+c を計算した",
      "-3: b=1+3=4と誤った"
    ]
  },
  "gqe-021": {
    "lead": "頂点(1,a-1)。a-1<0→a<1のとき正の実数解あり。",
    "steps": [
      "頂点y=a-1<0→a<1"
    ],
    "common_mistakes": [
      "a<=1"
    ]
  },
  "gqe-022": {
    "lead": "D=16-4k<0: k>4。",
    "steps": [
      "D<0→k>4"
    ],
    "common_mistakes": [
      "k>=4"
    ]
  },
  "gqe-023": {
    "lead": "|α-β|=√((α+β)²-4αβ)=√16=4。α+β=2, αβ=-3。",
    "steps": [
      "|3-(-1)|=4"
    ],
    "common_mistakes": [
      "16: √を付けなかった",
      "2: α+βを|α-β|とした",
      "虚数: +4αβと誤った"
    ]
  },
  "gqe-024": {
    "lead": "p=-2,q=0。",
    "steps": [
      "軸x=1→p=-2",
      "(2,0)代入→q=0"
    ],
    "common_mistakes": [
      "p=2"
    ]
  },
  "gqe-025": {
    "lead": "y=a(x-1)²-1にx=0: a-1=0→a=1。",
    "steps": [
      "a(0-1)²-1=0→a=1"
    ],
    "common_mistakes": [
      "-1: (-1)²=-1とした符号ミス",
      "-1: 頂点y座標=aと誤解",
      "2: y(1)=0と誤代入"
    ]
  },
  "gqe-026": {
    "lead": "D=k²-4k=0: k=4(k≠0)。",
    "steps": [
      "D=k(k-4)=0→k=4"
    ],
    "common_mistakes": [
      "k=2"
    ]
  },
  "gqe-027": {
    "lead": "x²-2x-k=0。積=-k=-3: k=3。",
    "steps": [
      "-k=-3→k=3"
    ],
    "common_mistakes": [
      "-3"
    ]
  },
  "gqe-028": {
    "lead": "頂点y=-1,端点y=3。-1<k<3で2交点。",
    "steps": [
      "-1<k<3"
    ],
    "common_mistakes": [
      "等号含む"
    ]
  },
  "gqe-029": {
    "lead": "y(a)=3→a(a-4)=0→a=4(a>2)。",
    "steps": [
      "(a-2)²=4→a=4"
    ],
    "common_mistakes": [
      "3: a²-4a=0の解を誤った",
      "2: 頂点を最大と誤解",
      "5: ≤3で解いた"
    ]
  },
  "gqe-030": {
    "lead": "m=-2,n=-3。",
    "steps": [
      "和2=-m→m=-2",
      "積-3=n"
    ],
    "common_mistakes": [
      "n=3"
    ]
  }
}