{
  "sf-001": {
    "lead": "三角形の相似条件は(1)3辺比、(2)2辺比と夾角、(3)2角。「2辺の比が等しい」だけでは不十分",
    "steps": [
      "3条件を確認",
      "2辺の比だけ（夾角なし）は不十分"
    ],
    "common_mistakes": [
      "2辺比だけで相似と判断する"
    ],
    "tips": [
      "辺2本の比を使うなら必ずその間の角(夾角)が必要"
    ]
  },
  "sf-002": {
    "lead": "相似比2:3 → BC:EF=2:3 → 6:EF=2:3 → EF=9cm",
    "steps": [
      "BC:EF=2:3",
      "6:EF=2:3",
      "EF=9"
    ],
    "common_mistakes": [
      "4cmと逆比で計算する"
    ],
    "tips": [
      "対応する辺の比=相似比。△ABCのBCに対応するのは△DEFのEF"
    ]
  },
  "sf-003": {
    "lead": "相似比3:1 → 面積比=3²:1²=9:1",
    "steps": [
      "面積比=(相似比)²",
      "3²:1²=9:1"
    ],
    "common_mistakes": [
      "3:1と相似比をそのまま使う"
    ],
    "tips": [
      "面積比は相似比の2乗"
    ]
  },
  "sf-004": {
    "lead": "面積比4:9 → 相似比=√4:√9=2:3",
    "steps": [
      "√(面積比)=相似比",
      "√4=2, √9=3",
      "相似比=2:3"
    ],
    "common_mistakes": [
      "4:9をそのまま相似比とする"
    ],
    "tips": [
      "面積比→相似比は√を取る"
    ]
  },
  "sf-005": {
    "lead": "∠A+∠B+∠C=180°、∠D+∠E+∠F=180°。∠A=∠D, ∠B=∠E なら ∠C=∠F",
    "steps": [
      "三角形の内角の和=180°",
      "∠C=180°-∠A-∠B=180°-∠D-∠E=∠F"
    ],
    "common_mistakes": [
      "∠C+∠F=180°と補角と混同する"
    ],
    "tips": [
      "3角のうち2角が等しければ残り1角も等しい"
    ]
  },
  "sf-006": {
    "lead": "中点連結定理：M,NがAB,ACの中点 → MN//BC かつ MN=BC/2",
    "steps": [
      "M,NはAB,ACの中点",
      "MN=BC/2"
    ],
    "common_mistakes": [
      "MN=BCと1/2を忘れる"
    ],
    "tips": [
      "中点を結ぶと長さは半分"
    ]
  },
  "sf-007": {
    "lead": "体積比=(相似比)³=1³:2³=1:8",
    "steps": [
      "体積比=(相似比)³",
      "1³:2³=1:8"
    ],
    "common_mistakes": [
      "1:4と2乗にする",
      "1:6と6倍にする"
    ],
    "tips": [
      "体積は3次元なので相似比を3乗する"
    ]
  },
  "sf-008": {
    "lead": "DE//BC のとき△ADE∽△ABC。AD:AB=AE:AC。よって AD:DB=AE:EC=2:3",
