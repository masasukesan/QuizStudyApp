      "AD:DB=AE:EC"
    ],
    "common_mistakes": [
      "3:2と逆にする"
    ],
    "tips": [
      "平行線があれば内分比は同じ側で対応"
    ]
  },
  "sf-009": {
    "lead": "相似比=AB:DE=6:9=2:3（最簡分数に）",
    "steps": [
      "6:9",
      "GCD=3 → 2:3"
    ],
    "common_mistakes": [
      "6:9のまま答える"
    ],
    "tips": [
      "相似比は最小整数比（既約）で表す"
    ]
  },
  "sf-010": {
    "lead": "3:4=9:DE → DE=12cm",
    "steps": [
      "3:4=9:x",
      "x=9×4/3=12"
    ],
    "common_mistakes": [
      "DE=6と9÷3×2=6と間違える"
    ],
    "tips": [
