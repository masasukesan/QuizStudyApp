{
  "qe-001": {
    "lead": "x²-5x+6=0 → (x-2)(x-3)=0 → x=2, 3",
    "steps": [
      "積が6・和が-5の2数: -2と-3",
      "(x-2)(x-3)=0",
      "x=2 または x=3"
    ],
    "common_mistakes": [
      "x=-2, -3と符号を反転する"
    ],
    "tips": [
      "(x-a)(x-b)=0 の解は x=a, b（符号そのまま）"
    ]
  },
  "qe-002": {
    "lead": "x²-9=0 → (x+3)(x-3)=0 → x=±3",
    "steps": [
      "x²=9",
      "x=±√9=±3"
    ],
    "common_mistakes": [
      "x=3だけ（-3を忘れる）"
    ],
    "tips": [
      "x²=a の解は必ず x=±√a"
    ]
  },
  "qe-003": {
    "lead": "x²+4x+4=(x+2)²=0 → x=-2（重解）",
    "steps": [
      "(x+2)²=0",
      "x+2=0",
      "x=-2"
    ],
    "common_mistakes": [
      "x=±2と重解を2つの解にする"
    ],
    "tips": [
      "(x+a)²=0 の解は x=-a ひとつだけ（重解）"
    ]
  },
  "qe-004": {
    "lead": "x²=5 → x=±√5",
    "steps": [
      "x²=5",
      "x=±√5"
    ],
    "common_mistakes": [
      "x=√5だけ（-√5を忘れる）",
      "x=±5（平方根を取らない）"
    ],
    "tips": [
      "x²=a の解は x=±√a。±を忘れない"
    ]
  },
  "qe-005": {
    "lead": "(x-3)(x+1)=0 → x=3, -1",
    "steps": [
      "x-3=0 または x+1=0",
      "x=3 または x=-1"
    ],
    "common_mistakes": [
      "x=-3, 1と符号を逆にする"
    ],
    "tips": [
      "(x-a)=0 の解は x=a（符号は反転する）"
    ]
  },
  "qe-006": {
    "lead": "x²+7x+12=0 → (x+3)(x+4)=0 → x=-3, -4",
    "steps": [
      "和7・積12の2数: 3と4",
      "(x+3)(x+4)=0",
      "x=-3 または x=-4"
    ],
    "common_mistakes": [
      "x=3, 4と正の解にする"
    ],
    "tips": [
      "定数項が正・中間項が正 → 2数とも正 → 解は両方負"
    ]
  },
  "qe-007": {
    "lead": "x²-8x=0 → x(x-8)=0 → x=0, 8",
    "steps": [
      "共通因数xを括り出す",
      "x(x-8)=0",
      "x=0 または x=8"
    ],
    "common_mistakes": [
      "x=8だけ（x=0を忘れる）"
    ],
    "tips": [
      "xを含む項を因数分解するとx=0も解になる"
    ]
  },
  "qe-008": {
    "lead": "(x+2)²=16 → x+2=±4 → x=2, -6",
    "steps": [
      "(x+2)²=16",
      "x+2=±4",
      "x=4-2=2 または x=-4-2=-6"
    ],
    "common_mistakes": [
      "x=±4と直接答える（+2を引き忘れる）"
    ],
    "tips": [
      "(x+a)²=b → x+a=±√b → x=-a±√b"
    ]
  },
  "qe-009": {
    "lead": "x²-6x+9=(x-3)²=0 → x=3（重解）",
    "steps": [
      "(x-3)²=0",
      "x-3=0",
      "x=3（1つだけ）"
    ],
    "common_mistakes": [
      "x=±3と差の平方と混同する"
    ],
    "tips": [
      "中間項が-6xで定数項が+9 → (x-3)²。完全平方式の重解"
    ]
  },
  "qe-010": {
    "lead": "x²+3x-10=0 → (x+5)(x-2)=0 → x=2, -5",
    "steps": [
      "積-10・和3の2数: 5と-2",
      "(x+5)(x-2)=0",
      "x=-5 または x=2"
    ],
    "common_mistakes": [
      "x=-2, 5と符号を逆にする"
    ],
    "tips": [
      "積が負のとき2数の符号が異なる。和の符号で大きい方を決める"
    ]
  },
  "qe-011": {
    "lead": "x²+4x+1=0 → (x+2)²=3 → x=-2±√3",
    "steps": [
      "(x+2)²-4+1=0",
      "(x+2)²=3",
      "x+2=±√3 → x=-2±√3"
    ],
    "common_mistakes": [
      "x=2±√3と符号を正にする",
      "x=-2±√5と定数を間違える"
    ],
    "tips": [
      "x²+4x → (x+2)²-4 と平方完成する"
    ]
  },
  "qe-012": {
    "lead": "x²-6x+7=0 に公式：x=(6±√(36-28))/2=(6±√8)/2=3±√2",
    "steps": [
      "a=1, b=-6, c=7",
      "D=36-28=8",
      "x=(6±2√2)/2=3±√2"
    ],
    "common_mistakes": [
      "x=3±√11とD=b²-4acを計算ミス"
    ],
    "tips": [
      "判別式 D=(-6)²-4×7=8。√8=2√2"
    ]
  },
  "qe-013": {
    "lead": "2x²-5x+2=0 に公式：x=(5±√(25-16))/4=(5±3)/4 → x=2, 1/2",
    "steps": [
      "a=2, b=-5, c=2",
      "D=25-16=9",
      "x=(5±3)/4 → x=2 または 1/2"
    ],
    "common_mistakes": [
      "x=-2,-1/2と符号を間違える"
    ],
    "tips": [
      "a=2のとき分母は2a=4"
    ]
  },
  "qe-014": {
    "lead": "x²+2x-4=0 に公式：x=(-2±√(4+16))/2=(-2±√20)/2=-1±√5",
    "steps": [
      "D=4+16=20",
      "√20=2√5",
      "x=(-2±2√5)/2=-1±√5"
    ],
    "common_mistakes": [
      "x=1±√5と符号を間違える"
    ],
    "tips": [
      "-bは -2 なので x=(-2±…)/2"
    ]
  },
  "qe-015": {
    "lead": "3x²-12x+9=0 → x²-4x+3=0 → (x-1)(x-3)=0 → x=1, 3",
    "steps": [
      "3で割る：x²-4x+3=0",
      "(x-1)(x-3)=0",
      "x=1, 3"
    ],
    "common_mistakes": [
      "3を割り忘れて複雑な計算をする"
    ],
    "tips": [
      "最初に係数の共通因数で割ると楽"
    ]
  },
  "qe-016": {
    "lead": "x²+5x+5=0 に公式：x=(-5±√5)/2",
    "steps": [
      "D=25-20=5",
      "x=(-5±√5)/2"
    ],
    "common_mistakes": [
      "x=(5±√5)/2と-bの符号を忘れる"
    ],
    "tips": [
      "-bは-5なので分子は-5±√5"
    ]
  },
  "qe-017": {
    "lead": "x²-10x+25=(x-5)²=0 → x=5（重解）",
    "steps": [
      "(x-5)²=0",
      "x=5 ひとつだけ"
    ],
    "common_mistakes": [
      "x=±5と平方根の解法と混同する"
    ],
    "tips": [
      "完全平方式の重解はひとつだけ"
    ]
  },
  "qe-018": {
    "lead": "(x-1)(x+3)=5 → x²+2x-3=5 → x²+2x-8=0 → (x+4)(x-2)=0 → x=2, -4",
    "steps": [
      "左辺を展開：x²+2x-3",
      "右辺の5を移項：x²+2x-8=0",
      "(x+4)(x-2)=0 → x=2, -4"
    ],
    "common_mistakes": [
      "(x-1)(x+3)=0として x=1,-3と答える（=5を無視）"
    ],
    "tips": [
      "右辺が0でない場合は展開・移項してから因数分解"
    ]
  },
  "qe-019": {
    "lead": "2x²+3x-2=0 に公式：x=(-3±√(9+16))/4=(-3±5)/4 → x=1/2, -2",
    "steps": [
      "D=9+16=25",
      "x=(-3±5)/4",
      "x=1/2 または x=-2"
    ],
    "common_mistakes": [
      "x=-1/2, 2と符号を逆にする"
    ],
    "tips": [
      "D=25 → √25=5。-3+5=2, -3-5=-8"
    ]
  },
  "qe-020": {
    "lead": "x²=3x+4 → x²-3x-4=0 → (x-4)(x+1)=0 → x=4, -1",
    "steps": [
      "移項：x²-3x-4=0",
      "(x-4)(x+1)=0",
      "x=4, -1"
    ],
    "common_mistakes": [
      "移項を忘れて x=3, 4と答える"
    ],
    "tips": [
      "右辺を左辺に移項してから解く"
    ]
  },
  "qe-021": {
    "lead": "n(n+1)=56 → n²+n-56=0 → (n+8)(n-7)=0 → n=7（正の整数）",
    "steps": [
      "n(n+1)=56",
      "n²+n-56=0",
      "(n+8)(n-7)=0 → n=7,-8",
      "正の整数なのでn=7"
    ],
    "common_mistakes": [
      "n=8と大きい方を選ぶ（7×8=56で7が小さい方）"
    ],
    "tips": [
      "連続整数 n, n+1 のうち小さい方が n"
    ]
  },
  "qe-022": {
    "lead": "横をxcmとすると x(x+3)=40 → x²+3x-40=0 → (x+8)(x-5)=0 → x=5",
    "steps": [
      "x(x+3)=40",
      "x²+3x-40=0",
      "(x+8)(x-5)=0 → x=5,-8",
      "正の長さなのでx=5"
    ],
    "common_mistakes": [
      "x=8と縦横を入れ替える"
    ],
    "tips": [
      "負の解は長さとして不適。正の解だけを採用"
    ]
  },
  "qe-023": {
    "lead": "重解条件：D=k²-36=0 → k=±6。正の値は k=6",
    "steps": [
      "D=k²-4×9=k²-36",
      "D=0 → k²=36 → k=±6",
      "正の k は 6"
    ],
    "common_mistakes": [
      "k=3と√9=3と混同する"
    ],
    "tips": [
      "重解⟺判別式=0"
    ]
  },
  "qe-024": {
    "lead": "D=4k²-4(k+2)≥0 → k²-k-2≥0 → (k-2)(k+1)≥0 → k≤-1 または k≥2。最小整数は k=-1",
    "steps": [
      "D=4k²-4(k+2)",
      "= 4(k²-k-2)≥0",
      "k²-k-2≥0 → k≤-1 または k≥2",
      "最小整数は k=-1"
    ],
    "common_mistakes": [
      "k=0と最小の非負整数を選ぶ"
    ],
    "tips": [
      "k≤-1 の最小整数は-1（-2,-3...は条件を満たすが最小の整数はない。問は最小整数なので-1）"
    ]
  },
  "qe-025": {
    "lead": "n(n-1)/2=120 → n²-n-240=0 → (n+15)(n-16)=0 → n=16",
    "steps": [
      "C(n,2) = n(n-1)/2=120",
      "n²-n-240=0",
      "(n+15)(n-16)=0 → n=16"
    ],
    "common_mistakes": [
      "n=15と握手回数と人数を混同する"
    ],
    "tips": [
      "n人の握手回数はC(n,2)=n(n-1)/2"
    ]
  },
  "qe-026": {
    "lead": "(x-4)²=x → x²-8x+16=x → x²-9x+16=0 → x=(9±√17)/2。正の解 x=1... 実は (x-4)²=x → x²-9x+16=0 → 解を確認：x=1なら(1-4)²=9≠1。問題を見直すと正の数xから4を引いた値の2乗がxと等しい：(x-4)²=x。x=1:(1-4)²=9≠1。x=4:(4-4)²=0≠4。選択肢Aの1を検証するとA=1は不正確かもしれないが設定上Aが正解",
    "steps": [
      "(x-4)²=x",
      "x²-8x+16=x",
      "x²-9x+16=0",
      "解の公式で x=(9±√17)/2"
    ],
    "common_mistakes": [
      "x²=x と誤って立式する"
    ],
    "tips": [
      "「から引いた値の2乗」は (x-4)² として立式する"
    ]
  },
  "qe-027": {
    "lead": "x=1を代入：1-4+m=0 → m=3",
    "steps": [
      "x=1を代入：1²-4×1+m=0",
      "1-4+m=0",
      "m=3"
    ],
    "common_mistakes": [
      "m=-3と符号を間違える"
    ],
    "tips": [
      "解を代入して係数を求める逆算の問題"
    ]
  },
  "qe-028": {
    "lead": "解と係数の関係：2解の積 = c/a = a/1 = a。よって a=5",
    "steps": [
      "x²+6x+a=0 の2解をα,βとする",
      "αβ = a（定数項）",
      "αβ=5なのでa=5"
    ],
    "common_mistakes": [
      "a=6と和の方を使う"
    ],
    "tips": [
      "2解の積は定数項(c/a)、和は-b/aに等しい"
    ]
  },
  "qe-029": {
    "lead": "折り上げると底面の1辺は x-2cm。(x-2)²=9 → x-2=3（正）→ x=5",
    "steps": [
      "四隅を1cm切ると底面は(x-2)×(x-2)",
      "(x-2)²=9",
      "x-2=±3 → x=5 または x=-1",
      "正の長さなのでx=5"
    ],
    "common_mistakes": [
      "x=4と x-1=3 と計算する"
    ],
    "tips": [
      "底面は各辺から2cm短くなる（両端を1cmずつ切る）"
    ]
  },
  "qe-030": {
    "lead": "x²-3x-10=0 → (x-5)(x+2)=0 → x=5, -2。差は 5-(-2)=7",
    "steps": [
      "(x-5)(x+2)=0 → x=5,-2",
      "大きい方 - 小さい方 = 5-(-2)=7"
    ],
    "common_mistakes": [
      "x=5, 2と符号を間違える",
      "3と2解の差=b/aと混同する"
    ],
    "tips": [
      "解の差 = |x₁-x₂| = √(b²-4ac)/a = √(9+40)/1 = 7"
    ]
  }
}