{
  "qa-001": {
    "lead": "y=2x² はa=2>0 なので原点を頂点とし上に開く放物線",
    "steps": [
      "a=2>0 → 上に開く",
      "頂点は(0,0)=原点",
      "対称軸はy軸"
    ],
    "common_mistakes": [
      "下に開くと逆に答える",
      "頂点が(2,0)と思う"
    ],
    "tips": [
      "a>0→上開き、a<0→下開き。頂点は常に原点"
    ]
  },
  "qa-002": {
    "lead": "y=-3x² はa=-3<0 なので原点を頂点とし下に開く放物線",
    "steps": [
      "a=-3<0 → 下に開く",
      "頂点は原点(0,0)"
    ],
    "common_mistakes": [
      "上に開くと間違える"
    ],
    "tips": [
      "aの符号だけで開き方が決まる"
    ]
  },
  "qa-003": {
    "lead": "y=3×2²=3×4=12",
    "steps": [
      "x²=4",
      "y=3×4=12"
    ],
    "common_mistakes": [
      "y=3×2=6 と2乗しない",
      "y=(3×2)²=36 と間違える"
    ],
    "tips": [
      "必ずx²を先に計算する"
    ]
  },
  "qa-004": {
    "lead": "y=2×(-3)²=2×9=18。x=-3でも(-3)²=9は正",
    "steps": [
      "(-3)²=9",
      "y=2×9=18"
    ],
    "common_mistakes": [
      "y=-18 と負のxで負のyと思う"
    ],
    "tips": [
      "偶数乗は常に正。(-3)²=9"
    ]
  },
  "qa-005": {
    "lead": "8=a×4 → a=2",
    "steps": [
      "y=ax²に(2,8)代入：8=a×4",
      "a=8÷4=2"
    ],
    "common_mistakes": [
      "a=8÷2=4 と2乗を忘れる"
    ],
    "tips": [
      "x²の値を先に計算してからaを求める"
    ]
  },
  "qa-006": {
    "lead": "9=a×(-3)²=9a → a=1",
    "steps": [
      "(-3)²=9",
      "9=9a → a=1"
    ],
    "common_mistakes": [
      "a=-1 と符号を間違える"
    ],
    "tips": [
      "(-3)²=9なので式は9=9a。aは正になる"
    ]
  },
  "qa-007": {
    "lead": "|½|<|2| なので y=½x² の方がグラフが開いている（なだらか）",
    "steps": [
      "|a|が小さいほど開いたグラフ",
      "½<2 なので y=½x² が広い"
    ],
    "common_mistakes": [
      "aが大きい方が広いと逆に思う"
    ],
    "tips": [
      "y=ax²のaの絶対値が大きいほど細いグラフ"
    ]
  },
  "qa-008": {
    "lead": "x=3のときy=9、x=0のときy=0。増加量=9-0=9",
    "steps": [
      "x=3:y=9, x=0:y=0",
      "増加量=9-0=9"
    ],
    "common_mistakes": [
      "変化の割合と混同して3と答える"
    ],
    "tips": [
      "y増加量はΔy=y₂-y₁"
    ]
  },
  "qa-009": {
    "lead": "y=-0²=0。どんな関数でもx=0のとき頂点y=0",
    "steps": [
      "x=0を代入",
      "y=-0²=0"
    ],
    "common_mistakes": [
      "y=-1と-x²=-1と思う"
    ],
    "tips": [
      "y=ax²は常に頂点が原点(0,0)"
    ]
  },
  "qa-010": {
    "lead": "y=3×(-2)²=3×4=12",
    "steps": [
      "(-2)²=4",
      "y=3×4=12"
    ],
    "common_mistakes": [
      "y=-12と負のxで負と思う"
    ],
    "tips": [
      "(-2)²=4>0。結果は必ず正"
    ]
  },
  "qa-011": {
    "lead": "変化の割合=(y₂-y₁)/(x₂-x₁)=(16-1)/(4-1)=15/3=5",
    "steps": [
      "x=1:y=1, x=4:y=16",
      "(16-1)/(4-1)=15/3=5"
    ],
    "common_mistakes": [
      "1と一次関数のようにaと答える",
      "15とx増加量で割らない"
    ],
    "tips": [
      "y=ax²の変化の割合はa(p+q)（pからqへの変化）"
    ]
  },
  "qa-012": {
    "lead": "変化の割合=(y₂-y₁)/(x₂-x₁)=(8-8)/(2-(-2))=0/4=0",
    "steps": [
      "x=-2:y=8, x=2:y=8（対称）",
      "(8-8)/4=0"
    ],
    "common_mistakes": [
      "4と対称であることを見落とす"
    ],
    "tips": [
      "y=ax²は偶関数。対称区間の変化の割合は0"
    ]
  },
  "qa-013": {
    "lead": "a=1>0なので最小は頂点x=0:y=0。最大はx=3:y=9。よって0≤y≤9",
    "steps": [
      "x=0:y=0（最小）",
      "x=3:y=9（最大、|3|>|-2|）",
      "0≤y≤9"
    ],
    "common_mistakes": [
      "4≤y≤9 と端点のみ見て頂点を忘れる"
    ],
    "tips": [
      "区間に原点が含まれるときはy=0が最小になる"
    ]
  },
  "qa-014": {
    "lead": "a=-1<0なので頂点が最大。x=0:y=0が最大",
    "steps": [
      "a<0→頂点が最大",
      "x=0:y=0が区間内",
      "最大値=0"
    ],
    "common_mistakes": [
      "y=-9や-4と最小値を答える"
    ],
    "tips": [
      "a<0のグラフは上から下に開く。頂点が最大"
    ]
  },
  "qa-015": {
    "lead": "1≤x≤3で原点を含まない。a>0なので最小はx=1:y=2",
    "steps": [
      "x=1:y=2×1=2（最小）",
      "x=3:y=2×9=18（最大）"
    ],
    "common_mistakes": [
      "y=0 と原点の値を最小と思う（区間外）"
    ],
    "tips": [
      "定義域に原点がない場合、端点を比較する"
    ]
  },
  "qa-016": {
    "lead": "変化の割合=(y₅-y₂)/(5-2)=(75-12)/3=63/3=21",
    "steps": [
      "x=2:y=12, x=5:y=75",
      "(75-12)/3=63/3=21"
    ],
    "common_mistakes": [
      "9と一次関数のようにaと答える"
    ],
    "tips": [
      "y=3x²の変化の割合=3(2+5)=21 ← a(p+q)公式"
    ]
  },
  "qa-017": {
    "lead": "-18=a×9 → a=-2",
    "steps": [
      "(-3)²=9",
      "-18=9a → a=-2"
    ],
    "common_mistakes": [
      "a=2と符号を落とす"
    ],
    "tips": [
      "yが負、x²は正なのでaは必ず負"
    ]
  },
  "qa-018": {
    "lead": "a=-2<0。区間は-3≤x≤2。|−3|>|2| なのでx=-3が最小",
    "steps": [
      "x=-3:y=-2×9=-18（最小）",
      "x=2:y=-2×4=-8",
      "最小値=-18"
    ],
    "common_mistakes": [
      "y=-8と|x|が小さい端点を選ぶ"
    ],
    "tips": [
      "a<0のとき、|x|が最大の点でyが最小になる"
    ]
  },
  "qa-019": {
    "lead": "x²=-x+6 → x²+x-6=0 → (x+3)(x-2)=0 → x=2（正の方）",
    "steps": [
      "x²=-x+6",
      "x²+x-6=0",
      "(x+3)(x-2)=0 → x=2,-3",
      "正の x は 2"
    ],
    "common_mistakes": [
      "x=3と直線y=-x+6のy切片と混同する"
    ],
    "tips": [
      "連立して代入・整理する"
    ]
  },
  "qa-020": {
    "lead": "変化の割合=(0-8)/(0-(-4))=-8/4=-2",
    "steps": [
      "x=-4:y=½×16=8, x=0:y=0",
      "(0-8)/(0-(-4))=-8/4=-2"
    ],
    "common_mistakes": [
      "2と絶対値を取る",
      "0と対称と思う（非対称）"
    ],
    "tips": [
      "x=-4から0は非対称。y=½x²で計算"
    ]
  },
  "qa-021": {
    "lead": "a(p+1)²-ap²=ap²+2ap+a-ap²=a(2p+1) と展開で確認できる",
    "steps": [
      "a(p+1)²=ap²+2ap+a",
      "ap²+2ap+a-ap²=a(2p+1) ✓"
    ],
    "common_mistakes": [
      "a(p+1)²-ap²をそのまま変化の割合と混同する"
    ],
    "tips": [
      "変化の割合の公式 a(p+q)=a(p+(p+1))=a(2p+1)"
    ]
  },
  "qa-022": {
    "lead": "傾き=(9-4)/(-3-2)=5/(-5)=-1",
    "steps": [
      "y変化: 9-4=5",
      "x変化: -3-2=-5",
      "傾き=5/(-5)=-1"
    ],
    "common_mistakes": [
      "5と変化量の比の符号を忘れる"
    ],
    "tips": [
      "傾き=(y₂-y₁)/(x₂-x₁)。順序を揃えて計算"
    ]
  },
  "qa-023": {
    "lead": "2x²=4x+6 → x²-2x-3=0 → (x-3)(x+1)=0 → x=3（正の方）",
    "steps": [
      "2x²=4x+6",
      "x²-2x-3=0",
      "(x-3)(x+1)=0 → x=3,-1",
      "正の x は 3"
    ],
    "common_mistakes": [
      "x=2と直線y=4x+6のxを代入して求めようとする"
    ],
    "tips": [
      "連立して整理。必ず整数になる"
    ]
  },
  "qa-024": {
    "lead": "y=x²上の(0,0)と(3,9)を結ぶ直線の傾き=(9-0)/(3-0)=3",
    "steps": [
      "原点(0,0)と(3,9)",
      "傾き=9/3=3"
    ],
    "common_mistakes": [
      "9と全体の変化量で答える"
    ],
    "tips": [
      "変化の割合=傾き=Δy/Δx"
    ]
  },
  "qa-025": {
    "lead": "変化の割合=(27-3)/(3-(-1))=24/4=6",
    "steps": [
      "x=-1:y=3, x=3:y=27",
      "(27-3)/4=24/4=6"
    ],
    "common_mistakes": [
      "9とa=3と答える",
      "12とΔxを2と計算する"
    ],
    "tips": [
      "y=3x²の変化の割合=3(-1+3)=3×2=6"
    ]
  },
  "qa-026": {
    "lead": "a=-1<0, 1≤x≤4（原点を含まない）。最大はx=1:y=-1, 最小はx=4:y=-16",
    "steps": [
      "x=1:y=-1（最大）",
      "x=4:y=-16（最小）",
      "値域: -16≤y≤-1"
    ],
    "common_mistakes": [
      "0が含まれると思う（区間に原点なし）"
    ],
    "tips": [
      "a<0で原点が区間外なら端点だけ比較"
    ]
  },
  "qa-027": {
    "lead": "|a|>|b| のとき y=ax² の方がy軸に近く細い（狭い）",
    "steps": [
      "|a|大→細いグラフ",
      "y=ax²がy=bx²より細い → |a|>|b|"
    ],
    "common_mistakes": [
      "a>bと符号込みで比較する"
    ],
    "tips": [
      "グラフの細さは|a|の大小で決まる"
    ]
  },
  "qa-028": {
    "lead": "y=2x²とy=-2x²はx軸に関して対称（y値の符号が逆）",
    "steps": [
      "同じxに対してyの符号が逆",
      "x軸対称"
    ],
    "common_mistakes": [
      "y軸対称と混同する"
    ],
    "tips": [
      "f(x)と-f(x)はx軸対称"
    ]
  },
  "qa-029": {
    "lead": "y=25 → x²=25 → x=±5",
    "steps": [
      "x²=25",
      "x=±5"
    ],
    "common_mistakes": [
      "x=5だけ（-5を忘れる）"
    ],
    "tips": [
      "x²=aの解は±√a。y=x²は偶関数なので±両方ある"
    ]
  },
  "qa-030": {
    "lead": "変化の割合=(16a-4a)/(4-2)=12a/2=6a=12 → a=2",
    "steps": [
      "x=2:y=4a, x=4:y=16a",
      "(16a-4a)/(4-2)=6a",
      "6a=12 → a=2"
    ],
    "common_mistakes": [
      "a=4とΔyのみで計算する"
    ],
    "tips": [
      "変化の割合=a(p+q)=a(2+4)=6a=12 → a=2"
    ]
  }
}