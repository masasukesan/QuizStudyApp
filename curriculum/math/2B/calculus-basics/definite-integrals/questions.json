{
  "questions": [
    {
      "id": "di-001",
      "subject": "数学",
      "unit": "calculus-basics",
      "difficulty": "basic",
      "question": "定積分 ∫₁³ x dx の計算として正しいものはどれか。",
      "choices": [
        {
          "label": "A",
          "text": "[x²/2]₁³ = 9/2−1/2 = 4"
        },
        {
          "label": "B",
          "text": "[x²]₁³ = 9−1 = 8"
        },
        {
          "label": "C",
          "text": "[x²/2]₁³ = 9/2+1/2 = 5"
        },
        {
          "label": "D",
          "text": "[x/2]₁³ = 3/2−1/2 = 1"
        }
      ],
      "correct": "A",
      "reasoning_tags": [
        "定積分"
      ],
      "subunit": "definite-integrals"
    },
    {
