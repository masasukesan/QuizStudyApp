        {
          "label": "C",
          "text": "∫₀² 2x dx = [x²]₀² = 4"
        },
        {
          "label": "D",
          "text": "∫₀² x dx = [x²/2]₀² = 2"
        }
      ],
      "correct": "B",
      "reasoning_tags": [
        "面積",
        "定積分"
      ],
      "subunit": "area-by-integration"
    },
