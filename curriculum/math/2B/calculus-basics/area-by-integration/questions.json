    {
      "id": "ab-001",
      "subject": "数学",
      "unit": "calculus-basics",
      "difficulty": "basic",
      "question": "x 軸と曲線 y=f(x) で囲まれた面積を定積分で表す式として正しいものはどれか(f(x)≥0 のとき)。",
      "choices": [
        {
          "label": "A",
          "text": "∫ₐᵇ f(x) dx の絶対値"
        },
        {
          "label": "B",
          "text": "∫ₐᵇ f(x) dx"
        },
        {
          "label": "C",
          "text": "∫ₐᵇ f'(x) dx"
        },
        {
          "label": "D",
          "text": "f(b)−f(a)"
        }
      ],
      "correct": "B",
      "reasoning_tags": [
        "面積",
        "定積分"
      ],
      "subunit": "area-by-integration"
    },
    {
