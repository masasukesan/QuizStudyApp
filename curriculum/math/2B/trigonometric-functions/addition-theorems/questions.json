        },
        {
          "label": "C",
          "text": "sin45°cos30° - cos45°sin30° = √6/4 - √2/4 = (√6-√2)/4"
        },
        {
          "label": "D",
          "text": "cos45°cos30° = (√2/2)(√3/2) = √6/4"
        }
      ],
      "correct": "A",
      "reasoning_tags": [
        "sin加法定理",
        "sin75°",
        "特殊角の計算"
      ]
    },
