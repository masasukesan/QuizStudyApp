        },
        {
          "label": "C",
          "text": "(tan45°-tan30°)/(1+tan45°tan30°) = (1-1/√3)/(1+1/√3) = 2-√3"
        },
        {
          "label": "D",
          "text": "tan45° × tan30° = 1 × √3/3 = √3/3"
        }
