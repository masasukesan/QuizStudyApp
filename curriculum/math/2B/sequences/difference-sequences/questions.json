    {
      "id": "ds-001",
      "pattern_id": "p01",
      "difficulty": "basic",
      "question": "数列 {aₙ} の階差数列が bₙ = 2n（a₁ = 3）のとき、一般項を求める手順として正しいものはどれか。",
      "choices": [
        {
          "label": "A",
          "text": "n≥2：aₙ=3+Σ[k=1,n−1]2k=3+2×(n−1)n/2=3+n(n−1)=n²−n+3"
        },
        {
          "label": "B",
          "text": "aₙ=a₁+bₙ=3+2n"
        },
        {
          "label": "C",
          "text": "aₙ=a₁×bₙ=3×2n=6n"
        },
        {
          "label": "D",
          "text": "n≥2：aₙ=3+Σ[k=1,n]2k=3+n(n+1)"
        }
      ],
      "correct": "A",
      "reasoning_tags": [
        "階差数列の一般項公式",
        "Σ[k=1,n−1]bₖ",
        "n=1の確認"
      ]
    },
