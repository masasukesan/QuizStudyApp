        {
          "label": "C",
          "text": "E(X)=1×(1/3)+2×(1/3)+3×(1/3)=2"
        },
        {
          "label": "D",
          "text": "E(X)=1+2+3=6"
        }
      ],
      "correct": "C",
      "reasoning_tags": [
