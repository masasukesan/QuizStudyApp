{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "_shared/schemas/question.schema.json",
  "title": "Question",
  "description": "問題生成部が出力する1問のJSON仕様。questions.json は items が30問のこのオブジェクト配列。",
  "type": "object",
  "required": ["id", "subject", "unit", "difficulty", "question", "choices", "correct"],
  "properties": {
    "id": {
      "type": "string",
      "description": "ユニーク識別子（例：math-1A-quadratic-functions-quadratic-equations-001）"
    },
    "subject": {
      "type": "string",
      "enum": ["japanese", "math", "english", "science", "social"]
    },
    "unit": {
      "type": "string",
      "description": "小単元名（日本語または英語ID）"
    },
    "difficulty": {
      "type": "string",
      "enum": ["basic", "standard", "exam"]
    },
    "question": {
      "type": "string",
      "description": "問題文。思考プロセスを問う表現にする。"
    },
    "choices": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["label", "text"],
        "properties": {
          "label": { "type": "string", "enum": ["A", "B", "C", "D"] },
          "text":  { "type": "string" }
        }
      }
    },
    "correct": {
      "type": "string",
      "enum": ["A", "B", "C", "D"],
      "description": "正解ラベル。必ず1つだけ。"
    },
    "reasoning_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "考え方・途中判断・落とし穴などのタグ"
    }
  }
}
